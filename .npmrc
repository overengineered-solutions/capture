# Route the @overengineered-solutions scope to PUBLIC npmjs for install.
# The user's global ~/.npmrc routes this scope to GHCR (npm.pkg.github.com);
# but capture and its OES siblings publish to public npmjs, so this local
# override makes install/CI resolution explicit and correct. No _authToken
# line is committed — publish auth comes from NODE_AUTH_TOKEN in CI.
@overengineered-solutions:registry=https://registry.npmjs.org
provenance=true
